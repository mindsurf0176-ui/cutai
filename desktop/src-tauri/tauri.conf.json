{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CutAI",
  "version": "0.1.0",
  "identifier": "com.cutai.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build && pnpm backend:bundle",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CutAI — AI Video Editor",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src http://127.0.0.1:18910 ws://127.0.0.1:18910; img-src 'self' http://127.0.0.1:18910 blob: data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "gen/backend"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
